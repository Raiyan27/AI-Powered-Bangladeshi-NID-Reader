# OpenRouter API settings
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Environment Mode: 'dev' or 'prod' (defaults gracefully to 'dev' if unset or invalid)
APP_ENV=dev

# Allowed CORS Origins (comma-separated list, e.g. for backend)
CORS_ORIGINS=http://localhost:3000,https://81t5j6p1-3000.asse.devtunnels.ms

# Backend API URL (for frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
