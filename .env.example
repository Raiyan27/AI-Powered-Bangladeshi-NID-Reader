# OpenRouter API settings
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# Environment Mode: 'dev' or 'prod' (defaults gracefully to 'dev' if unset or invalid)
APP_ENV=dev

# Custom .env file path (optional)
# DOTENV_PATH=.env

# Allowed CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000

# Backend API Configuration
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000
# MAX_UPLOAD_SIZE_MB=10
# MIN_IMAGE_DIMENSION=100
# MAX_IMAGE_DIMENSION=6000
# BACKEND_JPEG_QUALITY=95
# BACKEND_SUPPORTED_FORMATS=jpg,jpeg,png

# Vision AI Configuration
# VISION_MAX_TOKENS=1024
# VISION_TEMPERATURE=0.0
# VISION_TIMEOUT_S=90.0
# VISION_RETRY_ATTEMPTS=3
# VISION_RETRY_DELAY_S=1.0

# Frontend Configuration
# FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
